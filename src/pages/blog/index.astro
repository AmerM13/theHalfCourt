---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="blog">
			<header class="page-head">
				<h1>Blog</h1>
				<hr class="courtline" />
			</header>

			{
				posts.length === 0 ? (
					<div class="empty">
						<p class="empty-title">No articles yet.</p>
						<p>
							Breakdowns tip off soon. <a href="/">Subscribe</a> and you won't
							miss the first one.
						</p>
					</div>
				) : (
					<ul class="posts">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img
											class="thumb"
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
										/>
									)}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h3 class="title">{post.data.title}</h3>
									<p class="excerpt">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
		<style>
			.blog {
				width: 1000px;
				max-width: calc(100% - 2em);
				padding: 3em 1em 4em;
			}
			.page-head h1 {
				font-size: clamp(3rem, 7vw, 4.5rem);
				margin: 0 0 0.3em;
			}
			.posts {
				list-style: none;
				margin: 2.5em 0 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 2.5em 2em;
			}
			.posts a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.thumb {
				width: 100%;
				height: auto;
				border-radius: 6px;
				margin-bottom: 0.9em;
				border: 1px solid var(--line);
			}
			.date {
				font-family: var(--font-display), sans-serif;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-size: 0.85rem;
				color: var(--orange);
				margin: 0 0 0.25em;
			}
			.title {
				margin: 0 0 0.35em;
				font-size: 1.7rem;
				line-height: 1.05;
				transition: color 0.15s ease;
			}
			.excerpt {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.5;
			}
			.posts a:hover .title {
				color: var(--orange);
			}
			.empty {
				margin-top: 2.5em;
				padding: 2.5em 0;
			}
			.empty-title {
				font-family: var(--font-display), sans-serif;
				font-weight: 700;
				text-transform: uppercase;
				font-size: 1.8rem;
				color: rgb(var(--ink));
				margin: 0 0 0.3em;
			}
			.empty p:last-child {
				color: rgb(var(--gray));
				margin: 0;
			}
			@media (max-width: 640px) {
				.posts {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
