---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={SITE_TITLE}>
			<img src="/logo-trimmed.png" alt={SITE_TITLE} />
		</a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a
				class="social"
				href="https://x.com/"
				target="_blank"
				rel="noopener"
				aria-label="Follow The HalfCourt on X"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="19" height="19"
					><path
						fill="currentColor"
						d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
					></path></svg
				>
			</a>
			<a
				class="social"
				href="https://instagram.com/"
				target="_blank"
				rel="noopener"
				aria-label="Follow The HalfCourt on Instagram"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		background: var(--orange);
		border-bottom: 3px solid rgb(var(--ink));
		padding-left: env(safe-area-inset-left);
		padding-right: env(safe-area-inset-right);
	}
	nav {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		padding: 0.4em 0;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		line-height: 0;
	}
	.brand img {
		height: auto;
		width: auto;
		max-height: 88px;
		max-width: 100%;
		aspect-ratio: 827 / 205;
		object-fit: contain;
		border-radius: 0;
	}
	.links {
		display: flex;
		align-items: center;
		gap: 0.4em;
	}
	.links :global(a) {
		font-family: var(--font-display), sans-serif;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 1.05rem;
		color: rgb(var(--ink));
		text-decoration: none;
		padding: 0.35em 0.7em;
		border-radius: 4px;
	}
	.links :global(a:hover) {
		background: rgba(20, 18, 16, 0.08);
		color: rgb(var(--ink));
	}
	.links :global(a.active) {
		background: rgb(var(--ink));
		color: var(--orange);
		text-decoration: none;
		font-weight: 700;
	}
	.links :global(a.social) {
		display: inline-flex;
		align-items: center;
		padding: 0.35em 0.45em;
	}
	@media (max-width: 520px) {
		.brand img {
			max-height: 60px;
		}
		.links :global(a) {
			padding: 0.35em 0.5em;
			font-size: 0.95rem;
		}
	}
</style>
